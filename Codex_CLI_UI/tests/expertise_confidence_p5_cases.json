      "evidence": [{"claim": "Package health", "status": "verified", "sourceType": "local", "proof": "Local package receipt."}],
      "answer": "Package health passed.",
      "expectedLevel": "grounded"
    },
    {
      "id": "explicit-inference-is-bounded",
      "messages": [{"role": "user", "text": "Does the datasheet support this material choice?"}],
