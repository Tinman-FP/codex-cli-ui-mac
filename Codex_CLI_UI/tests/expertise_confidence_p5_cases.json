      "messages": [{"role": "user", "text": "Keep this conversation warm and concise."}],
      "route": {"objectivePlan": {"evidenceNeed": "none"}},
      "answer": "Yes. I will keep the response warm, direct, and concise.",
      "expectedLevel": "contextual"
    },
    {
      "id": "current-source-is-grounded",
      "messages": [{"role": "user", "text": "Is this product currently available?"}],
      "route": {"objectivePlan": {"evidenceNeed": "current-web-evidence"}},
      "answer": "It is available today. Source: https://store.example/product.",
      "expectedLevel": "grounded"
    },
    {
      "id": "local-receipt-is-grounded",
      "messages": [{"role": "user", "text": "Verify the local package health result."}],
