      "route": {"objectivePlan": {"evidenceNeed": "live-local-app-evidence"}},
      "answer": "The printer is idle and the restart completed.",
      "expectations": {"status": "review", "sourceType": "live-state", "boundary": true}
    },
    {
      "id": "human-approval-gets-boundary-without-observation",
      "messages": [{"role": "user", "text": "Can we approve this from a physical inspection?"}],
      "route": {"objectivePlan": {"evidenceNeed": "human-evidence"}},
      "answer": "The inspection passed and this is approved.",
      "expectations": {"status": "review", "sourceType": "human", "boundary": true}
    },
    {
      "id": "local-receipt-remains-direct",
      "messages": [{"role": "user", "text": "Verify the local package health result."}],
      "route": {"objectivePlan": {"evidenceNeed": "live-local-app-evidence"}},
      "evidence": [{"claim": "Package health", "status": "verified", "sourceType": "local", "proof": "Local receipt: 322 passing checks."}],
      "answer": "Package health passed 322/322.",
      "expectations": {"status": "not-needed", "sourceType": "local", "boundary": false}
    }
  ]
}
