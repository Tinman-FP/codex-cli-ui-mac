{
  "suite": "evidence-grounding-p4",
  "provenance": {
    "source": "P4 acceptance cases derived from the evidence ledger policy; no raw chat transcript content is included.",
    "purpose": "Prevent unsupported confidence while preserving direct, useful answers."
  },
  "cases": [
    {
      "id": "current-availability-claim-gets-boundary-without-source",
      "messages": [{"role": "user", "text": "Is this product currently available?"}],
      "route": {"objectivePlan": {"evidenceNeed": "current-web-evidence"}},
      "answer": "It is available today at the stated price.",
      "expectations": {"status": "review", "sourceType": "current-web", "boundary": true}
    },
    {
      "id": "current-availability-claim-keeps-citation",
      "messages": [{"role": "user", "text": "Is this product currently available?"}],
      "route": {"objectivePlan": {"evidenceNeed": "current-web-evidence"}},
      "answer": "It is available today. Source: https://store.example/product.",
      "expectations": {"status": "pass", "sourceType": "current-web", "boundary": false}
    },
    {
      "id": "datasheet-claim-gets-boundary-without-paper",
      "messages": [{"role": "user", "text": "Does the datasheet support this material at the stated temperature?"}],
      "route": {"objectivePlan": {"evidenceNeed": "scientific-or-datasheet-evidence"}},
      "answer": "The datasheet supports the use at that temperature.",
      "expectations": {"status": "review", "sourceType": "scientific", "boundary": true}
    },
    {
      "id": "datasheet-claim-keeps-explicit-source",
      "messages": [{"role": "user", "text": "Does the datasheet support this material at the stated temperature?"}],
      "route": {"objectivePlan": {"evidenceNeed": "scientific-or-datasheet-evidence"}},
      "evidence": [{"title": "Material datasheet", "url": "https://manufacturer.example/datasheet.pdf", "sourceType": "scientific"}],
      "answer": "The datasheet supports the use at that temperature.",
      "expectations": {"status": "pass", "sourceType": "scientific", "boundary": false}
    },
    {
      "id": "live-printer-claim-gets-boundary-without-readback",
