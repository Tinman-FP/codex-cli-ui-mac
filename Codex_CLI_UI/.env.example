CODEX_FREE_ONLY=1
CODEX_DEFAULT_PROFILE=manager
CODEX_DEFAULT_CWD=$HOME/Documents/Codex
CODEX_WEB_SEARCH=live

# Optional. Leave unset for free/local-only operation.
OPENAI_API_KEY=

# Optional local printer endpoint examples. Keep real values in private .env or data files.
QIDI_MOONRAKER_URL=http://printer-host.local:7125
